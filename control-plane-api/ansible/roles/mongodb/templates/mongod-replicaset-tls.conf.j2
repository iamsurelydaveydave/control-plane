# MongoDB configuration file for replica set mode with TLS
# Generated by Control Plane

storage:
  dbPath: /data/db
  wiredTiger:
    engineConfig:
      cacheSizeGB: {{ mongodb_cache_size_gb | default(0.5) }}

systemLog:
  destination: file
  logAppend: true
  path: /var/log/mongodb/mongod.log

net:
  port: 27017
  bindIp: 0.0.0.0
  tls:
    mode: requireTLS
    certificateKeyFile: /etc/mongodb/tls/server.pem
    CAFile: /etc/mongodb/tls/ca.crt
    allowConnectionsWithoutCertificates: true

security:
  authorization: enabled
  keyFile: /etc/mongodb-keyfile

replication:
  replSetName: {{ mongodb_replicaset_name }}

operationProfiling:
  slowOpThresholdMs: {{ mongodb_slow_op_threshold | default(100) }}
  mode: {{ mongodb_profiling_mode | default('slowOp') }}
