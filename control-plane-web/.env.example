# Control Plane Web - Environment Variables
# Copy this file to .env and update the values

# API URL - Full URL to the Control Plane API (for production builds)
# In development, the proxy in nuxt.config.ts handles /api routes
# In production (Cloudflare Workers), the frontend calls the API directly
API_URL=https://api.cplane.goweekdays.com

# Cookie domain for cross-subdomain authentication
# Should be the parent domain with a leading dot (e.g., .example.com)
# In development, leave empty or unset (cookies will be host-only)
COOKIE_DOMAIN=.cplane.goweekdays.com
