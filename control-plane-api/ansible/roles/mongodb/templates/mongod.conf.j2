# MongoDB configuration file for standalone mode
# Generated by Control Plane

storage:
  dbPath: /data/db
  wiredTiger:
    engineConfig:
      cacheSizeGB: {{ mongodb_cache_size_gb | default(0.5) }}

systemLog:
  destination: file
  logAppend: true
  path: /var/log/mongodb/mongod.log

net:
  port: 27017
  bindIp: 0.0.0.0

security:
  authorization: enabled

operationProfiling:
  slowOpThresholdMs: {{ mongodb_slow_op_threshold | default(100) }}
  mode: {{ mongodb_profiling_mode | default('slowOp') }}
