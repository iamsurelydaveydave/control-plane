// MongoDB initialization script
// Generated by Control Plane

// Switch to admin database
db = db.getSiblingDB('admin');

// Create root user if not exists
if (db.getUser('{{ mongodb_admin_user }}') === null) {
  db.createUser({
    user: '{{ mongodb_admin_user }}',
    pwd: '{{ mongodb_admin_password }}',
    roles: [
      { role: 'root', db: 'admin' },
      { role: 'userAdminAnyDatabase', db: 'admin' },
      { role: 'dbAdminAnyDatabase', db: 'admin' },
      { role: 'readWriteAnyDatabase', db: 'admin' }
    ]
  });
  print('Admin user created successfully');
}

{% if mongodb_databases is defined %}
// Create application databases and users
{% for database in mongodb_databases %}
db = db.getSiblingDB('{{ database.name }}');

if (db.getUser('{{ database.user }}') === null) {
  db.createUser({
    user: '{{ database.user }}',
    pwd: '{{ database.password }}',
    roles: [
      { role: 'readWrite', db: '{{ database.name }}' }
    ]
  });
  print('User {{ database.user }} created for database {{ database.name }}');
}
{% endfor %}
{% endif %}

print('MongoDB initialization complete');
