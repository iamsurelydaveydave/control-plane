{
  "name": "control-plane-api",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --watch .env --exec ts-node --files ./src/server.ts",
    "build": "tsc",
    "start": "node ./dist/server.js",
    "cli": "ts-node ./src/cli.ts",
    "cli:prod": "node ./dist/cli.js",
    "test": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register --require ./test/support/root-hooks.ts 'test/**/*.spec.ts' --exit",
    "test:unit": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register 'test/unit.spec.ts' --exit",
    "test:watch": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register --require ./test/support/root-hooks.ts 'test/**/*.spec.ts' --watch --watch-extensions ts",
    "test:caddy": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register --require ./test/support/root-hooks.ts 'test/caddy.service.spec.ts' --exit",
    "test:docker": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register --require ./test/support/root-hooks.ts 'test/docker.executor.spec.ts' --exit",
    "test:app": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register --require ./test/support/root-hooks.ts 'test/app.service.spec.ts' --exit",
    "test:database": "NODE_ENV=test mocha --require ts-node/register --require tsconfig-paths/register --require ./test/support/root-hooks.ts 'test/database.spec.ts' --exit",
    "lint": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "bcrypt": "^5.1.1",
    "cookie": "^0.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.17.0",
    "node-cron": "^3.0.3",
    "node-ssh": "^13.2.1",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.19.1",
        "prom-client": "^15.1.0",
        "typescript": "^5.2.2",
    "winston": "^3.13.0",
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/chai": "^4.3.16",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.6",
    "@types/ssh2": "^1.15.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "chai": "^4.3.10",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0"
  },
  "packageManager": "yarn@1.22.22"
}
