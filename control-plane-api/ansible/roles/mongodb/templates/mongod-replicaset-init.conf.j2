# MongoDB configuration file for replica set mode - INITIAL (no client auth)
# Generated by Control Plane
# This config is used during replica set initialization before auth is enabled

storage:
  dbPath: /data/db
  wiredTiger:
    engineConfig:
      cacheSizeGB: {{ mongodb_cache_size_gb | default(0.5) }}

systemLog:
  destination: file
  logAppend: true
  path: /var/log/mongodb/mongod.log

net:
  port: 27017
  bindIp: 0.0.0.0

# NO security section during init - allows localhost exception for first user creation
# keyFile will be enabled after admin user is created

replication:
  replSetName: {{ mongodb_replicaset_name }}

operationProfiling:
  slowOpThresholdMs: {{ mongodb_slow_op_threshold | default(100) }}
  mode: {{ mongodb_profiling_mode | default('slowOp') }}
